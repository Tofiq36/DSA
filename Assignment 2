#include<stdio.h>
#include<stdlib.h>
#define MAX 100

int stack1[MAX], top1 = -1;
int stack2[MAX], top2 = -1;

int isEmpty1(){
    return top1 == -1;
}

int isEmpty2(){
    return top2 == -1;
}

int isFull1(){
    return top1 == MAX-1;
}

int isFull2(){
    return top2 == MAX-1;
}

void PUSH(int s, int value){
    if(s == 1){
        if(isFull1())
            printf("Overflow\n");
        else{
            stack1[++top1] = value;
        }
    }
    else if(s == 2){
        if(isFull2())
            printf("Overflow\n");
        else{
            stack2[++top2] = value;
        }
    }
}

void POP(int s){
    if(s == 1){
        if(isEmpty1()){
            printf("Underflow\n");
            return;
        }
        printf("%d\n", stack1[top1]);
        top1--;
    }
    else if(s == 2){
        if(isEmpty2()){
            printf("Underflow\n");
            return;
        }
        printf("%d\n", stack2[top2]);
        top2--;
    }
}

void PEEK(int s){
    if(s == 1){
        if(isEmpty1()){
            printf("Underflow\n");
            return;
        }
        printf("%d\n", stack1[top1]);
    }
    else if(s == 2){
        if(isEmpty2()){
            printf("Underflow\n");
            return;
        }
        printf("%d\n", stack2[top2]);
    }
}

void DISPLAY(int s){
    if(s == 1){
        if(isEmpty1()){
            printf("Underflow\n");
            return;
        }
        for(int i=top1; i>=0; i--){
            printf("%d ", stack1[i]);
        }
        printf("\n");
    }
    else if(s == 2){
        if(isEmpty2()){
            printf("Underflow\n");
            return;
        }
        for(int i=top2; i>=0; i--){
            printf("%d ", stack2[i]);
        }
        printf("\n");
    }
}

int main(){
    int choice, s, val;
    
    while(1){
        printf("1. PUSH\n");
        printf("2. POP\n");
        printf("3. PEEK\n");
        printf("4. DISPLAY\n");
        printf("5. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        
        switch(choice){
            case 1:
                printf("Enter Stack(1/2): ");
                scanf("%d", &s);
                printf("Enter Value: ");
                scanf("%d", &val);
                PUSH(s, val);
                break;
                
            case 2:
                printf("Enter Stack(1/2): ");
                scanf("%d", &s);
                POP(s);
                break;
                
            case 3:
                printf("Enter Stack(1/2): ");
                scanf("%d", &s);
                PEEK(s);
                break;
                
            case 4:
                printf("Enter Stack(1/2): ");
                scanf("%d", &s);
                DISPLAY(s);
                break;
                
            case 5:
                exit(0);
                break;
                
            default:
                printf("Invalid Choice\n");
        }
        printf("\n");
    }
    return 0;
}
